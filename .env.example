# contextidx environment variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Vector Backends (configure the one you use) ───────────────────────────────
POSTGRES_URL=postgresql://user:pass@localhost:5432/contextidx
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
WEAVIATE_URL=http://localhost:8080
PINECONE_API_KEY=

# ── Metadata Store ────────────────────────────────────────────────────────────
# Defaults to SQLite (.contextidx/meta.db). Set to use PostgreSQL instead.
# CTXIDX_STORE_DSN=postgresql://user:pass@localhost:5432/contextidx

# ── Server (memorybench / FastAPI) ───────────────────────────────────────────
CONTEXTIDX_WINDOW_SIZE=8
CONTEXTIDX_STRIDE=3

# ── Logging ───────────────────────────────────────────────────────────────────
CTXIDX_LOG_LEVEL=INFO
